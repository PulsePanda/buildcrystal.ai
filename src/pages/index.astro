---
import Base from '../layouts/Base.astro';
import HeroChat from '../components/HeroChat.astro';
import CrystalMark from '../components/CrystalMark.astro';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Crystal AI",
  "url": "https://buildcrystal.ai",
  "description": "Crystal AI builds AI workers for specific job roles — receptionists, support reps, and more. Working 24/7, ready in days."
};
---

<Base
  title="Crystal AI — Talk to our receptionist. She's an AI."
  description="Lela is Crystal's AI receptionist. She picks up every call, books appointments, and works 24/7. Talk to her right now."
  ogTitle="Talk to our receptionist. She's an AI."
  ogDescription="Lela picks up every call, books appointments, and works 24/7. Try her live — no signup needed."
  active="home"
  jsonLd={websiteSchema}
>

  <!-- Background washes -->
  <div class="bg-washes" aria-hidden="true">
    <div class="bg-wash bg-wash-1"></div>
    <div class="bg-wash bg-wash-2"></div>
  </div>

  <!-- HERO — split layout: value prop + live chat -->
  <section class="hero">
    <div class="frame hero-grid">
      <div class="hero-text">
        <p class="eyebrow"><span class="dot" aria-hidden="true"></span>Live right now</p>
        <h1>Talk to our receptionist. She's an AI.</h1>
        <p class="sub">
          That's Lela. She picks up every call, books appointments, and hands off what she can't solve. No PTO, no sick days, no voicemail.
        </p>
        <div class="hero-stats">
          <div class="hero-stat"><strong>24/7</strong> &mdash; weekends and holidays too</div>
          <div class="hero-stat"><strong>3-5 days</strong> &mdash; plugged into your tools</div>
          <div class="hero-stat"><strong>28 days free</strong> &mdash; no card, cancel anytime</div>
        </div>
        <div class="hero-ctas">
          <a href="#roles" class="link-down">See all available workers &darr;</a>
        </div>
      </div>
      <HeroChat />
    </div>
  </section>

  <!-- ROLES -->
  <section class="band" id="roles">
    <div class="frame">
      <div class="section-head">
        <h2>Now available for hire.</h2>
        <span class="label">2 roles &middot; more coming</span>
      </div>

      <div class="roles">

        <article class="role">
          <div class="role-top">
            <div class="role-icon" aria-hidden="true">R</div>
            <span class="role-status">Available</span>
          </div>
          <h3>Receptionist</h3>
          <p class="role-for">For small-to-mid-sized businesses with an open front-desk seat.</p>
          <ul>
            <li>Answers every call in under a ring &mdash; identifies, captures intent, routes or books</li>
            <li>Books and reschedules against your existing calendar</li>
            <li>Logs every interaction and follows up the next morning</li>
            <li>Escalates judgment calls to the owner with a one-line summary</li>
          </ul>
          <div class="role-math">
            <div class="line"><span class="k">Coverage</span><span class="v">24 / 7</span></div>
          </div>
          <a href="/workers/receptionist" class="role-detail">Learn more about the receptionist &rarr;</a>
          <a href="#contact" class="apply" data-hire data-role="receptionist">Hire a receptionist &rarr;</a>
        </article>

        <article class="role">
          <div class="role-top">
            <div class="role-icon" aria-hidden="true">S</div>
            <span class="role-status">Available</span>
          </div>
          <h3>Support Rep</h3>
          <p class="role-for">For any business with a backed-up inbox, ticket queue, or chat widget.</p>
          <ul>
            <li>Works the inbox, ticket queue, and live chat &mdash; overnight, weekends, holidays</li>
            <li>Answers routine questions, resolves what it can resolve</li>
            <li>Routes refunds, complaints, and judgment calls to a named human</li>
            <li>Every correction sticks &mdash; same question doesn't stump it twice</li>
          </ul>
          <div class="role-math">
            <div class="line"><span class="k">Coverage</span><span class="v">24 / 7</span></div>
          </div>
          <a href="/workers/support" class="role-detail">Learn more about the support rep &rarr;</a>
          <a href="#contact" class="apply" data-hire data-role="support">Hire a support rep &rarr;</a>
        </article>

        <article class="role teaser">
          <div class="teaser-body">
            <div class="teaser-head">
              <div class="role-top">
                <div class="role-icon teaser-icon" aria-hidden="true">?</div>
                <span class="role-status pending">In build</span>
              </div>
              <h3>More roles coming.</h3>
            </div>
            <p class="role-for">Intake coordinators, bookkeepers, office managers, schedulers. If the seat you're hiring for isn't listed yet, tell us &mdash; we'll build it if it's a fit.</p>
          </div>
          <a href="#contact" class="apply teaser-apply" data-hire data-role="other">Tell us about your seat &rarr;</a>
        </article>

      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="band" id="how">
    <div class="frame">
      <div class="section-head">
        <h2>How it works.</h2>
        <span class="label">3 steps &middot; days, not weeks</span>
      </div>

      <div class="steps">
        <div class="step">
          <div class="num">STEP 01</div>
          <h3>Tell us the role.</h3>
          <p>Book a 15-minute working session. Describe the seat &mdash; what it does, where it lives, who the worker reports to.</p>
        </div>
        <div class="step">
          <div class="num">STEP 02</div>
          <h3>We onboard the worker.</h3>
          <p>We deploy it to your tools &mdash; phones, email, calendar, helpdesk &mdash; in 3&ndash;5 business days. We come out. We onboard it. We hang out.</p>
        </div>
        <div class="step">
          <div class="num">STEP 03</div>
          <h3>28-day free pilot.</h3>
          <p>It runs on your real work. You pay nothing for the first 28 days. On day 28 you decide. If you pass, we remove ourselves from your tools the same day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF + PILOT -->
  <section class="band">
    <div class="frame">
      <div class="section-head">
        <h2>It's a robot. It learns better.</h2>
      </div>

      <div class="proof">
        <div class="quote-card">
          <blockquote>One of the most expensive things a business can do is hire people.</blockquote>
          <p class="attrib">Posting, screening, interviewing, onboarding, ramp &mdash; weeks of lost time before anyone's useful. And that's when it works out.</p>
        </div>

        <div class="pilot-card">
          <span class="tag">The pilot</span>
          <h3>Try it free for 28 days.</h3>
          <p>New hires take weeks to ramp. So do ours. The difference: every correction sticks. The worker you have on day 30 is measurably better than the worker you had on day 1 &mdash; and keeps compounding from there.</p>
          <p class="kicker">If it's not working on day 28, we remove ourselves from your tools the same day.</p>
        </div>
      </div>

      <div class="run-own">
        <span class="mk" aria-hidden="true"><CrystalMark size={24} /></span>
        <p><strong>We use our own product.</strong> Our receptionist is a Crystal worker. So is our support rep. If you want a live demo, you're already talking to one when you call.</p>
      </div>
    </div>
  </section>

  <!-- SIGNUP -->
  <section class="signup-band band">
    <div class="frame">
      <div class="signup-wrap">
        <div>
          <h2>The build log.</h2>
          <p>Occasional notes as workers ship, pilots wrap, and we learn what actually works. No hype, no drip campaigns.</p>
        </div>
        <form class="signup" action="https://austinvanalstyne.substack.com/api/v1/free?nojs=true" method="post">
          <label for="email" class="sr-only">Email address</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@work.com"
            autocomplete="off"
          />
          <input type="hidden" name="first_url" value="https://buildcrystal.ai" />
          <input type="hidden" name="first_referrer" value="" />
          <input type="hidden" name="current_url" value="https://buildcrystal.ai" />
          <input type="hidden" name="current_referrer" value="" />
          <input type="hidden" name="referral_code" value="" />
          <input type="hidden" name="source" value="embed" />
          <button type="submit">Sign me up</button>
        </form>
      </div>
    </div>
  </section>

</Base>

<!-- Hide floating chat widget on homepage — the hero IS the chat -->
<style is:global>
  .cw { display: none !important; }
</style>

<style>
  /* Background washes */
  .bg-washes {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .bg-wash {
    position: absolute;
    border-radius: 50%;
  }
  .bg-wash-1 {
    top: -5%;
    right: -8%;
    width: 45vw;
    height: 45vw;
    background: radial-gradient(circle, var(--accent-wash) 0%, transparent 70%);
    opacity: 0.3;
  }
  .bg-wash-2 {
    bottom: -10%;
    left: -12%;
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, var(--paper-2) 0%, transparent 70%);
    opacity: 0.5;
  }

  /* HERO */
  .hero {
    position: relative;
    z-index: 1;
    padding: clamp(1.5rem, 4vw, 3rem) 0 clamp(2rem, 5vw, 4rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 1rem;
  }
  .eyebrow .dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 3px var(--accent-wash);
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.9); }
  }
  @media (prefers-reduced-motion: reduce) {
    .eyebrow .dot { animation: none; }
  }
  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .hero .sub {
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    color: var(--ink-muted);
    line-height: 1.55;
    margin: 0 0 2rem;
    max-width: 38ch;
  }
  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .hero-stat {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: var(--ink-muted);
  }
  .hero-stat strong {
    font-size: 0.95rem;
    color: var(--ink);
    font-weight: 600;
    font-family: var(--mono);
  }
  .hero-ctas {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .link-down {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--rule-strong);
    padding-bottom: 2px;
    transition: color 120ms, border-color 120ms;
  }
  .link-down:hover { color: var(--ink); border-color: var(--ink); }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 2rem;
    }
    .hero-text { order: 2; }
    .hero-stats { flex-direction: row; flex-wrap: wrap; gap: 1rem; }
  }

  /* ROLE CARDS */
  .roles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .role.teaser {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
  }
  .role.teaser .teaser-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }
  .role.teaser .teaser-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .role.teaser .role-top { flex: 0 0 auto; }
  .role.teaser h3 { margin: 0; flex: 0 0 auto; }
  .role.teaser .role-for { margin: 0; }
  .role.teaser .apply { width: auto; flex: 0 0 auto; margin: 0; }
  @media (max-width: 720px) {
    .roles { grid-template-columns: 1fr; }
    .role.teaser {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }
    .role.teaser .apply { width: 100%; }
  }
  .role {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 150ms ease, transform 150ms ease, box-shadow 150ms ease;
  }
  .role:hover {
    border-color: var(--rule-strong);
    box-shadow: 0 4px 20px -10px rgba(21, 23, 26, 0.15);
    transform: translateY(-2px);
  }
  .role-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .role-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ok);
    background: #e5f2ea;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
  }
  .role-status::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .role-status.pending { color: var(--ink-faint); background: #eee; }
  .role-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: var(--accent-wash);
    color: var(--accent-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.05rem;
    font-family: var(--mono);
  }
  .role-icon.teaser-icon {
    background: transparent;
    border: 1px dashed var(--rule-strong);
    color: var(--ink-faint);
  }
  .role h3 {
    font-size: 1.55rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0.35rem 0 0.25rem;
  }
  .role .role-for {
    color: var(--ink-muted);
    font-size: 0.95rem;
    margin: 0;
  }
  .role ul {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: var(--ink-2);
    font-size: 0.97rem;
  }
  .role ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.45;
  }
  .role ul li::before {
    content: "";
    width: 4px; height: 4px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 0.55em;
    flex-shrink: 0;
  }
  .role-math {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px dashed var(--rule-strong);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.92rem;
    color: var(--ink-muted);
  }
  .role-math .line {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .role-math .line .k { color: var(--ink-muted); }
  .role-math .line .v { color: var(--ink); font-family: var(--mono); font-size: 0.92rem; }
  .role-math .line.highlight .v { color: var(--accent-ink); font-weight: 600; }
  .role-detail {
    font-size: 0.85rem;
    color: var(--ink-muted);
    text-decoration: none;
    padding-top: 0.35rem;
    transition: color 120ms ease;
  }
  .role-detail:hover { color: var(--ink); }
  .role .apply {
    margin-top: 0.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.78rem 1rem;
    font-weight: 500;
    background: var(--ink);
    color: var(--paper);
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.98rem;
    transition: background 120ms ease;
  }
  .role .apply:hover { background: var(--accent); }
  .role.teaser {
    background: transparent;
    border-style: dashed;
  }
  .role.teaser h3 { color: var(--ink-muted); }
  .role.teaser .role-for { color: var(--ink-faint); }
  .apply.teaser-apply {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--rule-strong);
  }
  .apply.teaser-apply:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  /* STEPS */
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(16rem, 100%), 1fr));
    gap: 1.25rem;
  }
  .step {
    padding: 1.5rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: #fff;
  }
  .step .num {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--accent-ink);
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }
  .step h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    letter-spacing: -0.005em;
  }
  .step p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  /* PROOF */
  .proof {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 1.5rem;
  }
  @media (max-width: 820px) {
    .proof { grid-template-columns: 1fr; }
  }
  .quote-card {
    padding: 2rem 2.25rem;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
  }
  .quote-card blockquote {
    margin: 0;
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .quote-card .attrib {
    margin-top: 1rem;
    font-size: 0.88rem;
    color: var(--ink-muted);
  }
  .pilot-card {
    padding: 2rem 2.25rem;
    background: var(--ink);
    color: var(--paper);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
  }
  .pilot-card .tag {
    display: inline-flex;
    align-self: flex-start;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffe4d2;
    background: rgba(234, 90, 41, 0.28);
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    font-weight: 600;
  }
  .pilot-card h3 {
    font-size: 1.45rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .pilot-card p {
    color: #c7c9cf;
    margin: 0;
    font-size: 0.95rem;
  }
  .pilot-card .kicker {
    color: #ffe4d2;
    font-size: 0.9rem;
    margin: 0;
    padding-top: 0.25rem;
    border-top: 1px solid rgba(255, 228, 210, 0.2);
  }

  .run-own {
    margin-top: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--accent-wash);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .run-own .mk {
    color: var(--accent-ink);
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
  }
  .run-own p {
    margin: 0;
    flex: 1;
    color: var(--ink-2);
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .run-own p strong { color: var(--ink); font-weight: 600; }

  /* SIGNUP */
  .signup-band { padding: clamp(3rem, 6vw, 4.5rem) 0 clamp(2.5rem, 5vw, 3.5rem); }
  .signup-wrap {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (max-width: 720px) {
    .signup-wrap { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .signup-wrap h2 {
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    margin: 0 0 0.6rem;
    letter-spacing: -0.015em;
    font-weight: 600;
  }
  .signup-wrap p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.98rem;
  }
  .signup {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .signup input[type="email"] {
    flex: 1 1 16rem;
    min-width: 0;
    background: #fff;
    border: 1px solid var(--rule-strong);
    color: var(--ink);
    padding: 0.85rem 1rem;
    font-size: 1rem;
    border-radius: 8px;
    font-family: inherit;
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }
  .signup input[type="email"]::placeholder { color: var(--ink-faint); }
  .signup input[type="email"]:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-wash);
  }
  .signup button {
    background: var(--ink);
    color: var(--paper);
    border: 1px solid var(--ink);
    padding: 0.85rem 1.4rem;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .signup button:hover { background: var(--accent); border-color: var(--accent); }
</style>
