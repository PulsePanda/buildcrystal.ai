---
import Base from '../../layouts/Base.astro';
import CrystalMark from '../../components/CrystalMark.astro';

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI Workers by Crystal AI",
  "description": "Virtual employees for specific job roles. Managed AI workers hired out to small and mid-sized businesses.",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "url": "https://buildcrystal.ai/workers/receptionist",
      "name": "Crystal Receptionist"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "url": "https://buildcrystal.ai/workers/support",
      "name": "Crystal Support Rep"
    }
  ]
};
---

<Base
  title="AI Workers for Hire | Crystal AI"
  description="Browse Crystal AI's virtual employees — AI receptionists, support reps, and more roles coming. Half the cost of a human hire. Working 24/7. 28-day free pilot."
  ogTitle="AI Workers for Hire | Crystal AI"
  ogDescription="Virtual employees for the seats you're hiring for. Receptionists, support reps, more roles shipping. 28-day free pilot."
  active="workers"
  jsonLd={itemListSchema}
>

  <!-- HERO -->
  <section class="hero">
    <div class="frame">
      <p class="eyebrow">Workers for hire</p>
      <h1>Virtual employees for the seats you're hiring for.</h1>
      <p class="lede">
        Every Crystal worker is purpose-built for one specific role. Deployed to your tools. Running
        on your schedule. Correctable when it's wrong. You hire one. We build it. We run it.
      </p>
      <div class="hero-ctas">
        <a href="#available" class="btn btn-primary">See who's available</a>
        <a href="#contact" class="btn btn-secondary" data-hire data-role="general">Book a working session</a>
      </div>
      <div class="hero-meta">
        <div class="item"><strong>2 live</strong>ready to hire</div>
        <div class="item"><strong>3 in training</strong>shipping next</div>
        <div class="item"><strong>~50%</strong>of the cost</div>
        <div class="item"><strong>28 days</strong>free pilot, no card</div>
      </div>
    </div>
  </section>

  <!-- WHAT EVERY WORKER SHARES -->
  <section class="band" id="shared">
    <div class="frame">
      <div class="section-head">
        <h2>What every Crystal worker shares.</h2>
        <span class="label">The baseline, across every role</span>
      </div>

      <div class="shared-grid">
        <div class="shared">
          <span class="shared-mark" aria-hidden="true"><CrystalMark size={18} /></span>
          <h3>Managed service.</h3>
          <p>We build it, deploy it, run it, improve it. Not a tool you configure. Not a prompt builder.</p>
        </div>
        <div class="shared">
          <span class="shared-mark" aria-hidden="true"><CrystalMark size={18} /></span>
          <h3>28-day free pilot.</h3>
          <p>Pay nothing for the first 28 days. If you pass, we remove ourselves from your tools the same day.</p>
        </div>
        <div class="shared">
          <span class="shared-mark" aria-hidden="true"><CrystalMark size={18} /></span>
          <h3>You keep the kill switch.</h3>
          <p>Every worker has a stop button. You're in charge. Nothing customer-facing goes out without you being able to reverse it.</p>
        </div>
        <div class="shared">
          <span class="shared-mark" aria-hidden="true"><CrystalMark size={18} /></span>
          <h3>Every correction sticks.</h3>
          <p>Day one is rough. Day 30 it's genius. The worker you have on day 30 is measurably better than the one you had on day 1.</p>
        </div>
        <div class="shared">
          <span class="shared-mark" aria-hidden="true"><CrystalMark size={18} /></span>
          <h3>One monthly number.</h3>
          <p>Build, training, integrations, corrections, maintenance, updates, and AI usage &mdash; all bundled into one predictable retainer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AVAILABLE NOW -->
  <section class="band band-paper-2" id="available">
    <div class="frame">
      <div class="section-head">
        <h2>Available for hire now.</h2>
        <span class="label">2 workers live</span>
      </div>

      <div class="big-roles">

        <article class="big-role">
          <div class="big-role-top">
            <div class="big-role-icon" aria-hidden="true">R</div>
            <span class="big-role-status">Available</span>
          </div>
          <h3>Receptionist</h3>
          <p class="big-role-lede">
            Answers every call in under a ring, books and reschedules against your existing calendar,
            logs every interaction, and escalates judgment calls to the owner with a one-line summary.
          </p>
          <ul class="big-role-bullets">
            <li>24/7 coverage &mdash; nights, weekends, holidays</li>
            <li>Books appointments against Google Calendar, Microsoft 365, Acuity, Calendly</li>
            <li>Works with RingCentral, Twilio, Google Voice, 8x8</li>
            <li>Ready in 3&ndash;5 business days</li>
          </ul>
          <div class="big-role-math">
            <div class="bm-line"><span class="bm-k">Replaces</span><span class="bm-v">$50K/yr human seat</span></div>
            <div class="bm-line bm-highlight"><span class="bm-k">Your cost</span><span class="bm-v">~$2,100 / mo</span></div>
          </div>
          <div class="big-role-ctas">
            <a href="/workers/receptionist" class="btn btn-secondary">Read the detail page</a>
            <a href="#contact" class="btn btn-primary" data-hire data-role="receptionist">Hire a receptionist</a>
          </div>
        </article>

        <article class="big-role">
          <div class="big-role-top">
            <div class="big-role-icon" aria-hidden="true">S</div>
            <span class="big-role-status">Available</span>
          </div>
          <h3>Support Rep</h3>
          <p class="big-role-lede">
            Works your support inbox, ticket queue, or live chat &mdash; overnight, weekends, and
            holidays. Answers the routine questions, resolves what it can resolve, and routes
            anything that needs judgment to a named human with clean notes.
          </p>
          <ul class="big-role-bullets">
            <li>Works with Zendesk, Freshdesk, Intercom, Help Scout, Front</li>
            <li>Handles email, ticket queues, and live chat on the same knowledge base</li>
            <li>Every action logged &mdash; fully auditable</li>
            <li>Narrow scope closes 70&ndash;85% unassisted; rest routes to a human</li>
          </ul>
          <div class="big-role-math">
            <div class="bm-line"><span class="bm-k">Replaces</span><span class="bm-v">$50K/yr human seat</span></div>
            <div class="bm-line bm-highlight"><span class="bm-k">Your cost</span><span class="bm-v">~$2,000 / mo</span></div>
          </div>
          <div class="big-role-ctas">
            <a href="/workers/support" class="btn btn-secondary">Read the detail page</a>
            <a href="#contact" class="btn btn-primary" data-hire data-role="support">Hire a support rep</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- IN TRAINING -->
  <section class="band">
    <div class="frame">
      <div class="section-head">
        <h2>In training.</h2>
        <span class="label">3 more, shipping next</span>
      </div>

      <p class="training-intro">
        Three more roles are getting trained up right now. Getting in early lets you shape what the
        worker does from day one &mdash; if the seat you're trying to fill is one of these, tell us and
        we'll put you on the pilot list.
      </p>

      <div class="training-grid">
        <div class="training">
          <span class="training-tag">In training</span>
          <h3>Intake coordinator.</h3>
          <p>First-touch handling for new leads, patients, or clients &mdash; qualifying questions, forms, scheduling the first appointment, and handing off a clean record.</p>
          <a href="#contact" class="training-link" data-hire data-role="other">Tell us about your seat &rarr;</a>
        </div>
        <div class="training">
          <span class="training-tag">In training</span>
          <h3>Bookkeeper.</h3>
          <p>Categorizing transactions, chasing missing receipts, matching statements, flagging anomalies, and keeping the books caught up for your CPA every month.</p>
          <a href="#contact" class="training-link" data-hire data-role="other">Tell us about your seat &rarr;</a>
        </div>
        <div class="training">
          <span class="training-tag">In training</span>
          <h3>Scheduler.</h3>
          <p>Coordinating service calls, field-tech dispatch, or multi-party appointments &mdash; juggling calendars, confirmations, and changes without dropping the ball.</p>
          <a href="#contact" class="training-link" data-hire data-role="other">Tell us about your seat &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMON PROCESS -->
  <section class="band band-paper-2">
    <div class="frame">
      <div class="section-head">
        <h2>How every worker gets deployed.</h2>
        <span class="label">Same playbook for every role</span>
      </div>

      <div class="steps">
        <div class="step">
          <div class="num">STEP 01</div>
          <h3>Tell us the role.</h3>
          <p>Book a 15-minute working session. Describe the seat &mdash; what it does, where it lives, who the worker reports to, what's been driving you crazy about it.</p>
        </div>
        <div class="step">
          <div class="num">STEP 02</div>
          <h3>We onboard the worker.</h3>
          <p>We deploy it to your tools &mdash; phones, email, calendar, helpdesk &mdash; in 3&ndash;5 business days. We come out. We onboard it. We hang out.</p>
        </div>
        <div class="step">
          <div class="num">STEP 03</div>
          <h3>28-day free pilot.</h3>
          <p>It runs on your real work. You pay nothing for 28 days. On day 28 you decide. If you pass, we remove ourselves from your tools the same day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta-band">
    <div class="frame cta-wrap">
      <div>
        <h2>Hiring for a role we cover?</h2>
        <p>Book a 15-minute working session. We'll tell you honestly whether we're a fit.</p>
      </div>
      <a href="#contact" class="btn btn-primary big" data-hire data-role="general">Book a working session</a>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .hero { padding: clamp(3.5rem, 8vw, 6rem) 0 clamp(2.5rem, 6vw, 4rem); }
  .eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 1.25rem;
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }
  .hero .lede {
    font-size: clamp(1.05rem, 1.7vw, 1.25rem);
    color: var(--ink-muted);
    max-width: 56ch;
    margin: 0 0 2rem;
    line-height: 1.5;
  }
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .hero-meta {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(12rem, 100%), 1fr));
    gap: 1.5rem;
    color: var(--ink-muted);
    font-size: 0.92rem;
  }
  .hero-meta .item strong {
    display: block;
    color: var(--ink);
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }

  /* Alternating band color */
  .band-paper-2 { background: var(--paper-2); }

  /* SHARED GRID */
  .shared-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(15rem, 100%), 1fr));
    gap: 1rem;
  }
  .shared {
    padding: 1.25rem 1.35rem 1.1rem;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .shared-mark {
    color: var(--accent-ink);
    display: inline-flex;
    align-items: center;
  }
  .shared h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .shared p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  /* BIG ROLE CARDS */
  .big-roles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 820px) {
    .big-roles { grid-template-columns: 1fr; }
  }
  .big-role {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 2rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .big-role:hover {
    border-color: var(--rule-strong);
    box-shadow: 0 6px 24px -12px rgba(21, 23, 26, 0.18);
    transform: translateY(-2px);
  }
  .big-role-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .big-role-icon {
    width: 42px; height: 42px;
    border-radius: 8px;
    background: var(--accent-wash);
    color: var(--accent-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    font-family: var(--mono);
  }
  .big-role-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ok);
    background: #e5f2ea;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
  }
  .big-role-status::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .big-role h3 {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0.25rem 0 0.25rem;
    color: var(--ink);
  }
  .big-role-lede {
    margin: 0;
    color: var(--ink-muted);
    font-size: 1rem;
    line-height: 1.55;
  }
  .big-role-bullets {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: var(--ink-2);
    font-size: 0.93rem;
  }
  .big-role-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.5;
  }
  .big-role-bullets li::before {
    content: "";
    width: 4px; height: 4px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 0.55em;
    flex-shrink: 0;
  }
  .big-role-math {
    margin-top: auto;
    padding: 1rem 0;
    border-top: 1px dashed var(--rule-strong);
    border-bottom: 1px dashed var(--rule-strong);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .bm-line {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.93rem;
  }
  .bm-line .bm-k { color: var(--ink-muted); }
  .bm-line .bm-v { color: var(--ink); font-family: var(--mono); }
  .bm-line.bm-highlight .bm-v { color: var(--accent-ink); font-weight: 600; }
  .big-role-ctas {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .big-role-ctas .btn { flex: 1; justify-content: center; min-width: 11rem; }

  /* TRAINING */
  .training-intro {
    max-width: 62ch;
    color: var(--ink-muted);
    line-height: 1.55;
    font-size: 1rem;
    margin: -0.5rem 0 2rem;
  }
  .training-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(16rem, 100%), 1fr));
    gap: 1rem;
  }
  .training {
    padding: 1.5rem 1.5rem 1.25rem;
    background: #fff;
    border: 1px dashed var(--rule-strong);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .training-tag {
    display: inline-block;
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ink);
    background: var(--accent-wash);
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
  }
  .training h3 {
    margin: 0.2rem 0 0;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .training p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.93rem;
    line-height: 1.5;
  }
  .training-link {
    margin-top: auto;
    padding-top: 0.4rem;
    color: var(--ink);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 120ms ease;
  }
  .training-link:hover { color: var(--accent-ink); }

  /* STEPS (mirrored from homepage) */
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(16rem, 100%), 1fr));
    gap: 1.25rem;
  }
  .step {
    padding: 1.5rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: #fff;
  }
  .step .num {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--accent-ink);
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }
  .step h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    letter-spacing: -0.005em;
  }
  .step p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.95rem;
  }

  /* CTA band */
  .cta-band {
    padding: clamp(3rem, 6vw, 4.5rem) 0;
    background: var(--accent-wash);
    border-top: 1px solid var(--rule);
  }
  .cta-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-band h2 {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    margin: 0 0 0.4rem;
    letter-spacing: -0.015em;
    font-weight: 600;
  }
  .cta-band p {
    margin: 0;
    color: var(--ink-2);
    font-size: 1.02rem;
    max-width: 50ch;
  }
  .btn.big { padding: 1rem 1.5rem; font-size: 1rem; }
</style>
