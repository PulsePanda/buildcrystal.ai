---
import Base from '../../layouts/Base.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Crystal Receptionist",
  "description": "A virtual AI receptionist for small businesses. Answers every call in under a ring, books and reschedules appointments, logs every interaction, and escalates judgment calls. Working 24/7.",
  "brand": {
    "@type": "Brand",
    "name": "Crystal AI"
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What if the caller wants something the worker can't do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It takes a message and pings you. Short summary, caller name, callback number. If you set up escalation rules for specific topics — refunds, billing disputes, emergencies — those route directly to the right person."
      }
    },
    {
      "@type": "Question",
      "name": "Does it sound like a robot?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Less than you'd expect. It's warm, it's efficient, it uses contractions, it doesn't pretend to be human. If a caller asks whether they're talking to a person, it says no."
      }
    },
    {
      "@type": "Question",
      "name": "What happens the first time it screws up?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You correct it. The correction goes into the worker's knowledge base. The same mistake doesn't happen twice. The worker you have on day 30 is measurably different from the worker you had on day 1."
      }
    }
  ]
};
---

<Base
  title="AI Receptionist for Small Business | Crystal AI"
  description="Hire a virtual AI receptionist that answers every call, books appointments, and works 24/7. 28-day free pilot, no card required."
  ogTitle="AI Receptionist for Small Business | Crystal AI"
  ogDescription="Virtual receptionist that answers every call in under a ring, books appointments, and never calls in sick. 28-day free pilot."
  active="workers"
  jsonLd={[productSchema, faqSchema]}
>
  <article class="worker">
    <div class="frame">

      <!-- HEAD -->
      <header class="worker-head">
        <p class="eyebrow">Available for hire</p>
        <h1>Receptionist.</h1>
        <p class="lede">
          A virtual employee for your front desk. Answers every call in under a ring, books and
          reschedules against your existing calendar, logs every interaction, and escalates judgment
          calls to you.
        </p>
        <div class="head-meta">
          <div><strong>24 / 7</strong><span>coverage, no sick days</span></div>
          <div><strong>3&ndash;5 days</strong><span>from call to live</span></div>
          <div><strong>28 days</strong><span>free pilot</span></div>
        </div>
        <div class="head-ctas">
          <a href="#contact" class="btn btn-primary" data-hire data-role="receptionist">Hire a receptionist</a>
          <a href="#details" class="btn btn-secondary">See what it does</a>
        </div>
      </header>

      <!-- ROW 1: WHAT IT DOES  |  EXAMPLE CALL -->
      <section class="paired-section" id="details">
        <div class="paired-cols">
          <div class="pc-body">
            <p class="section-label">What it does</p>
            <h2>A Crystal receptionist, day to day.</h2>
            <ul class="does">
              <li>Answers every call in under a ring &mdash; identifies the caller, captures intent, routes or books.</li>
              <li>Books and reschedules appointments against your existing calendar.</li>
              <li>Logs every interaction. Follows up with no-shows the next morning.</li>
              <li>Escalates judgment calls to the owner with a one-line summary.</li>
              <li>Works nights, weekends, holidays. Doesn't take lunch.</li>
              <li>Every correction sticks &mdash; the same mistake doesn't happen twice.</li>
            </ul>

            <div class="sub-block">
              <h3>What it doesn't do.</h3>
              <p>
                Anything that needs hands or a face. Walk-ins, signing for packages, in-person greetings
                &mdash; that's still a human job, and we're upfront about it.
              </p>
              <p>
                Some businesses split the role: front desk stays human for the physical part, while
                phones, calendar, and email move to a Crystal receptionist.
              </p>
            </div>

            <div class="fit-card">
              <p class="fit-label">Typical fit</p>
              <ul class="fit-list">
                <li>Small-to-mid-sized business, $1M&ndash;$20M revenue</li>
                <li>Receptionist seat open 2+ weeks, or turning over regularly</li>
                <li>Owner currently covers phones between meetings</li>
                <li>Appointment-based business (medical, dental, trades, services)</li>
                <li>Open to splitting role if walk-ins require in-person</li>
              </ul>
            </div>
          </div>

          <div class="pc-body">
            <p class="section-label">Example call</p>
            <h2>What a real call sounds like.</h2>
            <p class="section-sub">Realistic pattern. Names fictional &mdash; your worker is trained on your specific calendar, schedule, and voice.</p>

            <div class="transcript">
              <div class="t-meta">11:47 AM &middot; Inbound &middot; Vet office</div>

              <div class="bubble caller">
                <span class="who">Caller</span>
                <p>Hey, I'm trying to get an appointment for my dog. He's been scratching his ears for a week.</p>
              </div>
              <div class="bubble worker">
                <span class="who">Crystal</span>
                <p>Sure. What's his name?</p>
              </div>
              <div class="bubble caller">
                <span class="who">Caller</span>
                <p>His name is Rocky.</p>
              </div>
              <div class="bubble worker">
                <span class="who">Crystal</span>
                <p>Got it. Does tomorrow at 2:30 or Thursday at 10 work better for you?</p>
              </div>
              <div class="bubble caller">
                <span class="who">Caller</span>
                <p>Thursday at 10 works.</p>
              </div>
              <div class="bubble worker">
                <span class="who">Crystal</span>
                <p>Got it. What is your name and call back number?</p>
              </div>
              <div class="bubble caller">
                <span class="who">Caller</span>
                <p>Megan Bryant, 555-0134.</p>
              </div>
              <div class="bubble worker">
                <span class="who">Crystal</span>
                <p>Thank you, Megan. I've got you booked for Rocky with Dr. Hale Thursday at 10 a.m. You should be getting a text reminder the night before. Anything else I can help you with?</p>
              </div>
              <div class="bubble caller">
                <span class="who">Caller</span>
                <p>Nope.</p>
              </div>
              <div class="bubble worker">
                <span class="who">Crystal</span>
                <p>Thank you, Megan. You have a good day.</p>
              </div>

              <div class="t-footer">
                <span class="tf-tag">Appointment booked</span>
                <span class="tf-tag">SMS queued</span>
                <span class="tf-tag">Logged to CRM</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ROW 2: WORKS WITH  |  MATH -->
      <section class="paired-section">
        <div class="paired-cols">
          <div class="pc-body">
            <p class="section-label">Works with</p>
            <h2>Your existing tools.</h2>
            <table class="def-table">
              <tbody>
                <tr><th>Phones</th><td>RingCentral &middot; Twilio &middot; Google Voice &middot; 8x8</td></tr>
                <tr><th>Calendars</th><td>Google Calendar &middot; Microsoft 365 &middot; Acuity &middot; Calendly</td></tr>
                <tr><th>Messaging</th><td>Slack &middot; Teams &middot; SMS</td></tr>
                <tr><th>Email</th><td>Gmail &middot; Outlook &middot; IMAP</td></tr>
              </tbody>
            </table>
            <p class="section-footnote">
              Don't see yours? Tell us on the working session. We'll build the connector or tell you it's not a fit.
            </p>
          </div>

          <div class="pc-body">
            <p class="section-label">Getting started</p>
            <h2>What deployment looks like.</h2>
            <table class="def-table">
              <tbody>
                <tr><th>Coverage</th><td>24 / 7</td></tr>
                <tr><th>Setup time</th><td>3&ndash;5 business days</td></tr>
                <tr><th>Free pilot</th><td>28 days, no card</td></tr>
              </tbody>
            </table>
            <p class="section-footnote">
              Book a working session to talk through pricing and fit.
            </p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="faq-section">
        <p class="section-label">Questions we get</p>
        <h2>Real questions, honest answers.</h2>
        <div class="faq">
          <div class="faq-item">
            <h3>What if the caller wants something the worker can't do?</h3>
            <p>It takes a message and pings you. Short summary, caller name, callback number. If you set up escalation rules for specific topics &mdash; refunds, billing disputes, emergencies &mdash; those route directly to the right person.</p>
          </div>
          <div class="faq-item">
            <h3>Does it sound like a robot?</h3>
            <p>Less than you'd expect. It's warm, it's efficient, it uses contractions, it doesn't pretend to be human. If a caller asks whether they're talking to a person, it says no.</p>
          </div>
          <div class="faq-item">
            <h3>What happens the first time it screws up?</h3>
            <p>You correct it. The correction goes into the worker's knowledge base. The same mistake doesn't happen twice. The worker you have on day 30 is measurably different from the worker you had on day 1.</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="worker-cta">
        <h3>Hiring a receptionist?</h3>
        <p>Book a 15-minute working session. We'll show you what one of ours would do in your shop.</p>
        <a href="#contact" class="btn btn-primary" data-hire data-role="receptionist">Book a working session</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .worker { padding: clamp(3rem, 7vw, 5rem) 0 clamp(3rem, 6vw, 4rem); }
  .worker-head { max-width: 60rem; margin-bottom: clamp(2rem, 5vw, 3rem); }
  .eyebrow {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 1rem;
  }
  .worker-head h1 {
    font-size: clamp(2.2rem, 4.8vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .worker-head .lede {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    color: var(--ink-muted);
    max-width: 52ch;
    margin: 0 0 1.75rem;
    line-height: 1.5;
  }
  .head-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(10rem, 100%), 1fr));
    gap: 1rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1.5rem;
  }
  .head-meta strong {
    display: block;
    font-size: 1.1rem;
    color: var(--ink);
    font-weight: 600;
  }
  .head-meta span { font-size: 0.85rem; color: var(--ink-muted); }
  .head-ctas { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  /* Shared section label */
  .section-label {
    display: inline-block;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 0.65rem;
  }
  .section-sub {
    color: var(--ink-muted);
    max-width: 52ch;
    font-size: 0.95rem;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }
  .section-footnote {
    margin: 1rem 0 0;
    color: var(--ink-muted);
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.5;
  }

  /* Paired column sections */
  .paired-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule);
  }
  .paired-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .paired-cols { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .pc-body h2 {
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .pc-body .sub-block {
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--rule);
  }
  .pc-body .sub-block h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .pc-body .sub-block p {
    margin: 0 0 0.8rem;
    color: var(--ink-2);
    font-size: 0.97rem;
    line-height: 1.55;
  }
  .pc-body .sub-block p:last-child { margin-bottom: 0; }
  .pc-body .fit-card { margin-top: 2rem; }

  /* Single-column section (used for "what it doesn't do" and honest part) */
  .worker-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule);
    max-width: 60rem;
  }
  .worker-section h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }
  .worker-section p {
    margin: 0 0 1rem;
    color: var(--ink-2);
    max-width: 62ch;
    line-height: 1.6;
  }
  .worker-section p:last-child { margin-bottom: 0; }

  /* "Does" list */
  .does {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1.5;
  }
  .does li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
  }
  .does li::before {
    content: "";
    width: 5px; height: 5px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 0.6em;
    flex-shrink: 0;
  }

  /* Transcript */
  .transcript {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .t-meta {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    margin-bottom: 0.85rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px dashed var(--rule);
  }
  .bubble {
    padding: 0.55rem 0.85rem;
    border-radius: 10px;
    margin-bottom: 0.45rem;
    max-width: 85%;
  }
  .bubble p { margin: 0; font-size: 0.9rem; line-height: 1.4; color: var(--ink); }
  .bubble .who {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.12rem;
  }
  .bubble.caller { background: var(--paper-2); margin-right: auto; }
  .bubble.caller .who { color: var(--ink-muted); }
  .bubble.worker { background: var(--accent-wash); margin-left: auto; }
  .bubble.worker .who { color: var(--accent-ink); }
  .t-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--rule);
  }
  .tf-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: #e5f2ea;
    color: var(--ok);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* Two-up (doesn't do + fit) */
  .two-up {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem;
  }
  @media (max-width: 760px) {
    .two-up { grid-template-columns: 1fr; }
  }
  .fit-card {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.5rem 1.5rem 1.25rem;
    align-self: start;
  }
  .fit-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin: 0 0 0.75rem;
  }
  .fit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.92rem;
    color: var(--ink-2);
    line-height: 1.45;
  }
  .fit-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }
  .fit-list li::before {
    content: "✓";
    color: var(--accent-ink);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Definition-style table (shared by works + math) */
  .def-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.93rem;
  }
  .def-table th, .def-table td {
    text-align: left;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    line-height: 1.45;
  }
  .def-table tr:first-child th,
  .def-table tr:first-child td {
    border-top: 1px solid var(--rule);
  }
  .def-table th {
    font-weight: 500;
    color: var(--ink-muted);
    width: 38%;
    padding-right: 1rem;
  }
  .def-table td { color: var(--ink); }

  /* FAQ */
  .faq-section {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--rule);
  }
  .faq-section h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }
  .faq {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 1rem;
    max-width: 60rem;
  }
  .faq-item {
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
  }
  .faq-item h3 {
    font-size: 1.02rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--ink);
    line-height: 1.3;
  }
  .faq-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  /* CTA */
  .worker-cta {
    margin-top: 2.5rem;
    padding: 2rem 2.25rem;
    background: var(--accent-wash);
    border-radius: var(--radius);
    max-width: 56rem;
  }
  .worker-cta h3 { margin: 0 0 0.4rem; font-size: 1.25rem; font-weight: 600; }
  .worker-cta p { margin: 0 0 1rem; color: var(--ink-2); }
</style>
