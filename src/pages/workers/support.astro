---
import Base from '../../layouts/Base.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Crystal Support Rep",
  "description": "A virtual AI support rep for small and mid-sized businesses. Works the support inbox, ticket queue, and live chat — handles routine questions, resolves what it can, routes judgment calls to a named human. Works 24/7.",
  "brand": {
    "@type": "Brand",
    "name": "Build Crystal"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "2000",
    "unitText": "month",
    "availability": "https://schema.org/InStock"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What percentage of tickets does it close on its own?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depends on the scope you define at setup. A narrow scope (FAQs, order status, account questions, common how-tos) closes 70–85% unassisted. Anything outside that scope routes to a named human with full context and suggested next steps."
      }
    },
    {
      "@type": "Question",
      "name": "What about refunds, escalations, and complaints?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Judgment calls route to a human immediately. The worker does not issue refunds, resolve complaints, or make customer-affecting decisions without you being able to reverse them. Kill switch is on every deployment. We set the routing rules together at setup."
      }
    },
    {
      "@type": "Question",
      "name": "Can it work across email, tickets, and live chat at the same time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Same worker, same knowledge base, all your channels. If a customer starts in chat and follows up over email, the worker picks up the thread. One worker, one brain — not three disconnected bots."
      }
    }
  ]
};
---

<Base
  title="AI Support Rep for Small Business | Build Crystal"
  description="Hire a virtual AI support rep that works your inbox, ticket queue, and live chat — 24/7. Handles routine questions, routes judgment calls to a human. ~$2,000/mo. 28-day free pilot."
  ogTitle="AI Support Rep for Small Business | Build Crystal"
  ogDescription="Virtual support rep that clears your inbox and queue around the clock. Closes 70–85% of routine tickets. ~$2,000/mo. 28-day free pilot, no card required."
  active="workers"
  jsonLd={[productSchema, faqSchema]}
>
  <article class="worker">
    <div class="frame">

      <!-- HEAD -->
      <header class="worker-head">
        <p class="eyebrow">Available for hire</p>
        <h1>Support Rep.</h1>
        <p class="lede">
          A virtual employee for your support load. Works your inbox, ticket queue, and live chat,
          answers the routine questions, resolves what it can, and routes anything that needs
          judgment to a named human with clean notes.
        </p>
        <div class="head-meta">
          <div><strong>~$2,000 / mo</strong><span>~50% of the human hire</span></div>
          <div><strong>24 / 7</strong><span>inbox + queue coverage</span></div>
          <div><strong>3&ndash;5 days</strong><span>from call to live</span></div>
          <div><strong>28 days</strong><span>free pilot</span></div>
        </div>
        <div class="head-ctas">
          <a href="#contact" class="btn btn-primary" data-hire data-role="support">Hire a support rep</a>
          <a href="#details" class="btn btn-secondary">See what it does</a>
        </div>
      </header>

      <!-- ROW 1: WHAT IT DOES  |  EXAMPLE TICKET -->
      <section class="paired-section" id="details">
        <div class="paired-cols">
          <div class="pc-body">
            <p class="section-label">What it does</p>
            <h2>A Crystal support rep, day to day.</h2>
            <ul class="does">
              <li>Works your support inbox, ticket queue, and live chat &mdash; overnight, weekends, holidays.</li>
              <li>Answers routine questions using your knowledge base, product docs, and past resolved tickets.</li>
              <li>Handles order status, account questions, common how-tos, and FAQ-shaped inquiries on its own.</li>
              <li>Routes judgment calls &mdash; refunds, complaints, escalations &mdash; to a named human with context.</li>
              <li>Logs every action and tool call. Fully auditable.</li>
              <li>Every correction sticks &mdash; the same question doesn't stump it twice.</li>
            </ul>

            <div class="sub-block">
              <h3>What it doesn't do.</h3>
              <p>
                Anything that should take judgment, empathy, or policy discretion. Refunds,
                complaint resolution, account suspensions, any customer-affecting decision &mdash;
                those route to a human you name at setup. The worker handles volume; humans handle
                judgment.
              </p>
              <p>
                Anything customer-facing before you're ready. Most deployments start internal-only
                or draft-for-review, with you approving the first wave of replies, until you're
                confident letting the worker send on its own.
              </p>
            </div>

            <div class="fit-card">
              <p class="fit-label">Typical fit</p>
              <ul class="fit-list">
                <li>Small-to-mid business with a growing support load</li>
                <li>Support inbox or ticket queue backed up regularly</li>
                <li>Founder or ops lead covering tickets between real work</li>
                <li>20%+ of volume is repeat "how do I" or "where's my" questions</li>
                <li>Peak-hour or overnight coverage gaps</li>
              </ul>
            </div>
          </div>

          <div class="pc-body">
            <p class="section-label">Example ticket</p>
            <h2>What a real support ticket looks like.</h2>
            <p class="section-sub">Realistic pattern. Names fictional &mdash; your worker is trained on your product, policies, and escalation rules.</p>

            <div class="transcript">
              <div class="t-meta">Ticket #8492 &middot; Help Scout &middot; 10:18 PM</div>

              <div class="ticket-msg from-user">
                <span class="who">jordan.reyes@email.com</span>
                <span class="when">10:18 PM</span>
                <p><strong>Where's my order?</strong></p>
                <p>Hey, I ordered three pairs of pants last Thursday and the tracking hasn't moved in two days. What's going on?</p>
              </div>
              <div class="ticket-msg from-worker">
                <span class="who">Crystal &middot; Support</span>
                <span class="when">10:19 PM</span>
                <p>Hey Jordan &mdash; let me take a look. Order #8492 shipped Thursday night and is with FedEx. Tracking shows it's been sitting at their regional hub in Memphis since Friday because of weather delays there.</p>
                <p>Most packages clear that hub in 24&ndash;48 hours. I've set up a status watch and I'll email you as soon as it moves. If it hasn't moved by Wednesday, I'll flag it to the team and we can talk about a replacement or a refund.</p>
              </div>
              <div class="ticket-msg from-user">
                <span class="who">jordan.reyes@email.com</span>
                <span class="when">10:21 PM</span>
                <p>Okay, that works. Thanks for digging in.</p>
              </div>
              <div class="ticket-msg from-worker">
                <span class="who">Crystal &middot; Support</span>
                <span class="when">10:21 PM</span>
                <p>Anytime. You'll hear from me the moment it moves.</p>
              </div>

              <div class="t-footer">
                <span class="tf-tag">Resolved &mdash; 3 min</span>
                <span class="tf-tag">Status watch set</span>
                <span class="tf-tag">Follow-up scheduled</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ROW 2: WORKS WITH  |  MATH -->
      <section class="paired-section">
        <div class="paired-cols">
          <div class="pc-body">
            <p class="section-label">Works with</p>
            <h2>Your existing stack.</h2>
            <table class="def-table">
              <tbody>
                <tr><th>Helpdesk / Ticketing</th><td>Zendesk &middot; Freshdesk &middot; Intercom &middot; Help Scout &middot; Front</td></tr>
                <tr><th>Email</th><td>Gmail &middot; Outlook &middot; shared inbox tools</td></tr>
                <tr><th>Live chat</th><td>Intercom &middot; Drift &middot; Crisp &middot; Tidio</td></tr>
                <tr><th>CRM</th><td>HubSpot &middot; Salesforce &middot; Pipedrive</td></tr>
              </tbody>
            </table>
            <p class="section-footnote">
              Don't see yours? Tell us on the working session. We'll build the connector or tell you it's not a fit.
            </p>
          </div>

          <div class="pc-body">
            <p class="section-label">The math</p>
            <h2>What it costs.</h2>
            <table class="def-table">
              <tbody>
                <tr><th>Market salary (loaded)</th><td>~$50,000 / yr</td></tr>
                <tr><th>Crystal support rep</th><td>~$2,000 / mo</td></tr>
                <tr><th>Coverage</th><td>24 / 7 (overnights &amp; weekends)</td></tr>
                <tr><th>Setup time</th><td>3&ndash;5 business days</td></tr>
                <tr><th>Free trial</th><td>28 days, no card</td></tr>
              </tbody>
            </table>
            <p class="section-footnote">
              One monthly number. Worker, build-out, training, integrations, corrections, maintenance, updates, and AI usage all included.
            </p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="faq-section">
        <p class="section-label">Questions we get</p>
        <h2>Real questions, honest answers.</h2>
        <div class="faq">
          <div class="faq-item">
            <h3>What percentage of tickets does it close on its own?</h3>
            <p>Depends on the scope you define at setup. A narrow scope (FAQs, order status, account questions, common how-tos) closes 70&ndash;85% unassisted. Anything outside that scope routes to a named human with full context and suggested next steps.</p>
          </div>
          <div class="faq-item">
            <h3>What about refunds, escalations, and complaints?</h3>
            <p>Judgment calls route to a human immediately. The worker doesn't issue refunds, resolve complaints, or make customer-affecting decisions without you being able to reverse them. Kill switch is on every deployment. We set routing rules together at setup.</p>
          </div>
          <div class="faq-item">
            <h3>Can it work across email, tickets, and chat at the same time?</h3>
            <p>Yes. Same worker, same knowledge base, all your channels. If a customer starts in chat and follows up over email, the worker picks up the thread. One worker, one brain &mdash; not three disconnected bots.</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="worker-cta">
        <h3>Hiring for support?</h3>
        <p>Book a 15-minute working session. We'll walk through your current inbox or queue and show you what one of ours would do with it.</p>
        <a href="#contact" class="btn btn-primary" data-hire data-role="support">Book a working session</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .worker { padding: clamp(3rem, 7vw, 5rem) 0 clamp(3rem, 6vw, 4rem); }
  .worker-head { max-width: 60rem; margin-bottom: clamp(2rem, 5vw, 3rem); }
  .eyebrow {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }
  .worker-head h1 {
    font-size: clamp(2.2rem, 4.8vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .worker-head .lede {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    color: var(--ink-muted);
    max-width: 52ch;
    margin: 0 0 1.75rem;
    line-height: 1.5;
  }
  .head-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 1rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1.5rem;
  }
  .head-meta strong {
    display: block;
    font-size: 1.1rem;
    color: var(--ink);
    font-weight: 600;
  }
  .head-meta span { font-size: 0.85rem; color: var(--ink-muted); }
  .head-ctas { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  .section-label {
    display: inline-block;
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.65rem;
  }
  .section-sub {
    color: var(--ink-muted);
    max-width: 52ch;
    font-size: 0.95rem;
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }
  .section-footnote {
    margin: 1rem 0 0;
    color: var(--ink-muted);
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.5;
  }

  /* Paired column sections */
  .paired-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule);
  }
  .paired-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .paired-cols { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .pc-body h2 {
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .pc-body .sub-block {
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--rule);
  }
  .pc-body .sub-block h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .pc-body .sub-block p {
    margin: 0 0 0.8rem;
    color: var(--ink-2);
    font-size: 0.97rem;
    line-height: 1.55;
  }
  .pc-body .sub-block p:last-child { margin-bottom: 0; }
  .pc-body .fit-card { margin-top: 2rem; }

  /* "Does" list */
  .does {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1.5;
  }
  .does li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
  }
  .does li::before {
    content: "";
    width: 5px; height: 5px;
    background: var(--accent);
    border-radius: 50%;
    margin-top: 0.6em;
    flex-shrink: 0;
  }

  /* Transcript (ticket style) */
  .transcript {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .t-meta {
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    margin-bottom: 0.85rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px dashed var(--rule);
  }
  .ticket-msg {
    padding: 0.7rem 0.9rem;
    border-radius: 8px;
    margin-bottom: 0.6rem;
    border-left: 3px solid var(--rule-strong);
    background: var(--paper-2);
  }
  .ticket-msg.from-worker {
    background: var(--accent-wash);
    border-left-color: var(--accent);
  }
  .ticket-msg .who {
    display: inline-block;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--ink);
    margin-right: 0.55rem;
  }
  .ticket-msg .when {
    font-size: 0.68rem;
    color: var(--ink-faint);
    font-family: var(--mono);
  }
  .ticket-msg p {
    margin: 0.35rem 0 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--ink-2);
  }
  .ticket-msg p strong { color: var(--ink); font-weight: 600; }
  .t-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--rule);
  }
  .tf-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: #e5f2ea;
    color: var(--ok);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .fit-card {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 1.5rem 1.5rem 1.25rem;
  }
  .fit-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .fit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.92rem;
    color: var(--ink-2);
    line-height: 1.45;
  }
  .fit-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }
  .fit-list li::before {
    content: "✓";
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Def table shared by works + math */
  .def-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.93rem;
  }
  .def-table th, .def-table td {
    text-align: left;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    line-height: 1.45;
  }
  .def-table tr:first-child th,
  .def-table tr:first-child td {
    border-top: 1px solid var(--rule);
  }
  .def-table th {
    font-weight: 500;
    color: var(--ink-muted);
    width: 38%;
    padding-right: 1rem;
  }
  .def-table td { color: var(--ink); }

  /* FAQ */
  .faq-section {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--rule);
  }
  .faq-section h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }
  .faq {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1rem;
    max-width: 60rem;
  }
  .faq-item {
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
  }
  .faq-item h3 {
    font-size: 1.02rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--ink);
    line-height: 1.3;
  }
  .faq-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--ink-2);
    line-height: 1.55;
  }

  /* CTA */
  .worker-cta {
    margin-top: 2.5rem;
    padding: 2rem 2.25rem;
    background: var(--accent-wash);
    border-radius: var(--radius);
    max-width: 56rem;
  }
  .worker-cta h3 { margin: 0 0 0.4rem; font-size: 1.25rem; font-weight: 600; }
  .worker-cta p { margin: 0 0 1rem; color: var(--ink-2); }
</style>
