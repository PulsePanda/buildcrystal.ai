---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'workers' | 'about';
  ogTitle?: string;
  ogDescription?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description = 'Build Crystal builds AI workers for specific job roles — receptionists, support reps, more on the way. Half the cost of a human hire, working 24/7, ready in days.',
  active,
  ogTitle,
  ogDescription,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://buildcrystal.ai';
const canonicalUrl = `${siteUrl}${Astro.url.pathname === '/' ? '' : Astro.url.pathname}`;

const ogImageUrl = `${siteUrl}/favicon.svg`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Build Crystal",
  "url": siteUrl,
  "logo": ogImageUrl,
  "description": "Build Crystal builds purpose-built AI workers for specific job roles — receptionists, support reps, and more. Half the cost of a human hire, working 24/7.",
  "founder": {
    "@type": "Person",
    "name": "Austin VanAlstyne"
  }
};

const schemas = [organizationSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Build Crystal" />
  <meta property="og:image" content={ogImageUrl} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Structured Data -->
  {schemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <Nav active={active} />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer />
  <ContactModal />
</body>
</html>
