---
const year = new Date().getFullYear();
---

<footer class="site">
  <div class="frame foot-row">
    <p>&copy; {year} Build Crystal &middot; By <a href="https://austinv.me">Austin VanAlstyne</a></p>
    <p>Better Workers For Your Business.</p>
  </div>
</footer>

<style>
  footer.site {
    border-top: 1px solid var(--rule);
    padding: 2rem 0 2.5rem;
  }
  .foot-row {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    color: var(--ink-faint);
    font-size: 0.88rem;
  }
  .foot-row a {
    color: var(--ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 120ms ease, color 120ms ease;
  }
  .foot-row a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink-muted);
  }
  .foot-row p { margin: 0; }
</style>
