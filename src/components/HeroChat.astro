---
// HeroChat — inline chat panel for the homepage hero section.
// Always visible (not a floating widget). Plays an intro sequence on load,
// then connects to ops.buildcrystal.ai/public/chat for real conversation.
---

<div class="hc" id="hero-chat">
  <div class="hc-header">
    <div class="hc-avatar">L</div>
    <div class="hc-header-text">
      <span class="hc-name">Lela</span>
      <span class="hc-role">AI Receptionist</span>
    </div>
    <div class="hc-online">Online</div>
    <a href="tel:+17632974244" class="hc-call">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Call her
    </a>
  </div>
  <div class="hc-messages" id="hc-messages">
    <div class="hc-typing" id="hc-typing">
      <span class="hc-dot"></span>
      <span class="hc-dot"></span>
      <span class="hc-dot"></span>
    </div>
  </div>
  <div class="hc-input" id="hc-input-area">
    <input type="text" id="hc-input" placeholder="Message Lela..." autocomplete="off" maxlength="2000" />
    <button type="button" id="hc-send" aria-label="Send">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  const messagesEl = document.getElementById('hc-messages')!;
  const typingEl = document.getElementById('hc-typing')!;
  const inputArea = document.getElementById('hc-input-area')!;
  const inputEl = document.getElementById('hc-input') as HTMLInputElement;
  const sendBtn = document.getElementById('hc-send')!;

  let threadId: string | null = null;
  let sending = false;
  let introComplete = false;

  // --- Intro sequence ---
  const introSequence = [
    { type: 'agent', text: "Hey — I'm Lela. I run the front desk here at Crystal.", delay: 800 },
    { type: 'user', text: "Wait, you're not a real person?", delay: 2000 },
    { type: 'agent', text: "Nope! I'm AI. But I pick up every call, book appointments, take messages, and hand off anything tricky to the right human. I just don't take lunch breaks.", delay: 1400 },
    { type: 'agent', text: "Go ahead — ask me something, or pretend you're calling in. I'll show you how it works.", delay: 1200 },
  ];
  let seqIndex = 0;

  function showTyping() {
    typingEl.classList.add('visible');
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function hideTyping() {
    typingEl.classList.remove('visible');
  }

  function addMsg(text: string, from: 'user' | 'agent') {
    const div = document.createElement('div');
    div.className = `hc-msg hc-msg-${from}`;

    if (from === 'agent') {
      const bubble = document.createElement('div');
      bubble.className = 'hc-bubble';
      const dirty = marked.parse(text, { breaks: true, async: false }) as string;
      bubble.innerHTML = DOMPurify.sanitize(dirty, { USE_PROFILES: { html: true } });
      div.appendChild(bubble);
    } else {
      const p = document.createElement('p');
      p.textContent = text;
      div.appendChild(p);
    }

    messagesEl.insertBefore(div, typingEl);
    requestAnimationFrame(() => div.classList.add('visible'));
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function playIntro() {
    if (seqIndex >= introSequence.length) {
      introComplete = true;
      hideTyping();
      setTimeout(() => {
        inputArea.classList.add('invite');
        inputEl.focus();
      }, 600);
      return;
    }

    const step = introSequence[seqIndex];

    if (step.type === 'agent') {
      showTyping();
      setTimeout(() => {
        hideTyping();
        addMsg(step.text, 'agent');
        seqIndex++;
        setTimeout(playIntro, 400);
      }, step.delay);
    } else {
      setTimeout(() => {
        addMsg(step.text, 'user');
        seqIndex++;
        setTimeout(playIntro, 500);
      }, step.delay);
    }
  }

  setTimeout(playIntro, 600);

  // --- Real chat ---
  async function sendMessage() {
    const text = inputEl.value.trim();
    if (!text || sending) return;

    sending = true;
    inputArea.classList.remove('invite');
    inputEl.value = '';
    addMsg(text, 'user');
    showTyping();

    try {
      const resp = await fetch('https://ops.buildcrystal.ai/public/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, thread_id: threadId }),
      });

      if (!resp.ok) throw new Error(`${resp.status}`);

      const data = await resp.json();
      threadId = data.thread_id || threadId;
      hideTyping();
      addMsg(data.response || "Hmm, I'm having a moment. Try again?", 'agent');
    } catch {
      hideTyping();
      addMsg("Something went wrong on my end. Give it another shot in a sec.", 'agent');
    }

    sending = false;
    inputEl.focus();
  }

  sendBtn.addEventListener('click', sendMessage);
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage();
  });
</script>

<style is:global>
  .hc {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    height: clamp(460px, 70vh, 620px);
    box-shadow: 0 8px 40px -12px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.02);
    overflow: hidden;
    transition: box-shadow 300ms ease;
  }
  .hc:hover {
    box-shadow: 0 12px 50px -12px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.03);
  }

  /* Header */
  .hc-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .hc-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700;
  }
  .hc-name { display: block; font-weight: 600; font-size: 0.88rem; }
  .hc-role { display: block; font-size: 0.72rem; color: var(--ink-muted); }
  .hc-online {
    margin-left: auto;
    display: flex; align-items: center; gap: 0.35rem;
    font-size: 0.72rem; color: var(--ok); font-weight: 500;
  }
  .hc-online::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ok);
    animation: hc-online-pulse 3s ease-in-out infinite;
  }
  @keyframes hc-online-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Call button */
  .hc-call {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: 0.5rem;
    padding: 0.45rem 0.85rem;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 8px;
    transition: background 120ms ease, transform 120ms ease;
    white-space: nowrap;
  }
  .hc-call:hover {
    background: var(--accent-hover);
    transform: scale(1.03);
  }
  .hc-call svg { flex-shrink: 0; }

  /* Messages */
  .hc-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .hc-msg {
    max-width: 82%;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 300ms ease, transform 300ms ease;
  }
  .hc-msg.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .hc-msg p,
  .hc-msg .hc-bubble {
    margin: 0;
    padding: 0.75rem 1rem;
    border-radius: 16px;
    font-size: 0.9rem;
    line-height: 1.5;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .hc-msg-agent {
    align-self: flex-start;
  }
  .hc-msg-agent .hc-bubble {
    background: rgba(0,0,0,0.04);
    color: var(--ink);
    border-bottom-left-radius: 4px;
  }
  .hc-msg-user {
    align-self: flex-end;
  }
  .hc-msg-user p {
    background: var(--ink);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  /* Markdown inside agent bubbles */
  .hc-bubble > *:first-child { margin-top: 0; }
  .hc-bubble > *:last-child { margin-bottom: 0; }
  .hc-bubble p { margin: 0.4em 0; padding: 0; background: none; max-width: none; border-radius: 0; font-size: inherit; line-height: inherit; }
  .hc-bubble a { color: var(--accent); text-decoration: underline; }
  .hc-bubble a:hover { color: var(--accent-hover); }
  .hc-bubble code { background: rgba(0,0,0,0.06); padding: 0.1em 0.35em; border-radius: 4px; font-size: 0.85em; font-family: var(--mono); }
  .hc-bubble ul, .hc-bubble ol { margin: 0.35em 0; padding-left: 1.25rem; }
  .hc-bubble li { margin: 0.1em 0; }
  .hc-bubble li > p { margin: 0; }

  /* Typing indicator */
  .hc-typing {
    align-self: flex-start;
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 0.85rem 1rem;
    background: rgba(0,0,0,0.04);
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .hc-typing.visible { opacity: 1; }
  .hc-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ink-muted);
    opacity: 0.4;
    animation: hc-bounce 1.2s ease-in-out infinite;
  }
  .hc-dot:nth-child(2) { animation-delay: 0.15s; }
  .hc-dot:nth-child(3) { animation-delay: 0.3s; }
  @keyframes hc-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* Input */
  .hc-input {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--rule);
  }
  .hc-input input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 0.9rem;
    font-family: inherit;
    background: transparent;
    color: var(--ink);
    padding: 0.4rem 0;
  }
  .hc-input input::placeholder { color: var(--ink-faint); }
  .hc-input button {
    background: none;
    border: none;
    color: var(--ink-muted);
    cursor: pointer;
    padding: 0.3rem;
    display: flex; align-items: center;
    transition: color 120ms;
  }
  .hc-input button:hover { color: var(--accent); }

  /* Nudge after intro */
  .hc-input.invite::after {
    content: "Go ahead — she's live";
    position: absolute;
    bottom: calc(100% + 6px);
    left: 1rem;
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 500;
    opacity: 0;
    animation: hc-nudge 400ms ease forwards;
    animation-delay: 0.5s;
  }
  @keyframes hc-nudge {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Scrollbar */
  .hc-messages::-webkit-scrollbar { width: 4px; }
  .hc-messages::-webkit-scrollbar-track { background: transparent; }
  .hc-messages::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.06); border-radius: 2px; }

  @media (max-width: 820px) {
    .hc { height: 55vh; min-height: 400px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hc-msg { opacity: 1; transform: none; transition: none; }
    .hc-dot { animation: none; }
    .hc-online::before { animation: none; }
  }
</style>
