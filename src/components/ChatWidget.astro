---
// ChatWidget — immersive chat experience.
// Minimized: light pill button centered at bottom.
// Open: blurred backdrop, semi-transparent panel, feels like a conversation takeover.
// Talks to ops.buildcrystal.ai/public/chat → Lela (reception agent).
---

<div id="chat-widget" class="cw">
  <!-- Collapsed button -->
  <button id="cw-toggle" class="cw-bar" aria-label="Chat with Lela">
    <span>Chat</span>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    <span id="cw-badge" class="cw-badge" hidden></span>
  </button>

  <!-- Backdrop overlay -->
  <div id="cw-backdrop" class="cw-backdrop" hidden></div>

  <!-- Chat panel -->
  <div id="cw-panel" class="cw-panel" hidden>
    <div class="cw-header">
      <div class="cw-header-info">
        <span class="cw-avatar">L</span>
        <div>
          <span class="cw-name">Lela</span>
          <span class="cw-status">Crystal Reception</span>
        </div>
      </div>
      <button id="cw-close" class="cw-close" aria-label="Close chat">&times;</button>
    </div>
    <div id="cw-messages" class="cw-messages">
      <div class="cw-msg cw-msg-agent">
        <div class="cw-bubble">Hi, I'm Lela and I'm here to help. What can I do for you?</div>
      </div>
    </div>
    <form id="cw-form" class="cw-input">
      <input id="cw-input" type="text" placeholder="Message..." autocomplete="off" maxlength="2000" />
      <button type="submit" class="cw-send" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </form>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  const toggle = document.getElementById('cw-toggle')!;
  const panel = document.getElementById('cw-panel')!;
  const backdrop = document.getElementById('cw-backdrop')!;
  const closeBtn = document.getElementById('cw-close')!;
  const form = document.getElementById('cw-form') as HTMLFormElement;
  const input = document.getElementById('cw-input') as HTMLInputElement;
  const messages = document.getElementById('cw-messages')!;

  const badge = document.getElementById('cw-badge')!;

  let threadId: string | null = null;
  let sending = false;
  let isOpen = false;
  let hasUnread = false;

  function showBadge() {
    if (!isOpen) {
      hasUnread = true;
      badge.hidden = false;
    }
  }

  function clearBadge() {
    hasUnread = false;
    badge.hidden = true;
  }

  function open() {
    isOpen = true;
    clearBadge();
    toggle.hidden = true;
    backdrop.hidden = false;
    panel.hidden = false;
    requestAnimationFrame(() => {
      backdrop.classList.add('cw-backdrop-visible');
      panel.classList.add('cw-panel-visible');
    });
    input.focus();
  }

  function close() {
    isOpen = false;
    backdrop.classList.remove('cw-backdrop-visible');
    panel.classList.remove('cw-panel-visible');
    setTimeout(() => {
      backdrop.hidden = true;
      panel.hidden = true;
      toggle.hidden = false;
    }, 250);
  }

  toggle.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  function addMessage(text: string, from: 'user' | 'agent') {
    const div = document.createElement('div');
    div.className = `cw-msg cw-msg-${from}`;
    // Agents get Markdown rendering (sanitized). Users render as plain text —
    // no markdown parsing on user input keeps echoes literal and removes any
    // XSS surface from user-controlled content.
    if (from === 'agent') {
      const bubble = document.createElement('div');
      bubble.className = 'cw-bubble';
      const dirty = marked.parse(text, { breaks: true, async: false }) as string;
      bubble.innerHTML = DOMPurify.sanitize(dirty, { USE_PROFILES: { html: true } });
      div.appendChild(bubble);
    } else {
      const p = document.createElement('p');
      p.textContent = text;
      div.appendChild(p);
    }
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addTyping(): HTMLElement {
    const div = document.createElement('div');
    div.className = 'cw-msg cw-msg-agent cw-typing';
    div.innerHTML = '<div class="cw-bubble"><span class="cw-dot"></span><span class="cw-dot"></span><span class="cw-dot"></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return div;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || sending) return;

    sending = true;
    input.value = '';
    addMessage(text, 'user');
    const typing = addTyping();

    try {
      const resp = await fetch('https://ops.buildcrystal.ai/public/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: text,
          thread_id: threadId,
        }),
      });

      if (!resp.ok) throw new Error(`${resp.status}`);

      const data = await resp.json();
      threadId = data.thread_id || threadId;
      typing.remove();
      addMessage(data.response || "I'm having trouble responding right now. Please try again.", 'agent');
      showBadge();
    } catch (err) {
      typing.remove();
      addMessage("Something went wrong. Please try again in a moment.", 'agent');
      showBadge();
      console.warn('[chat widget] error:', err);
    }

    sending = false;
    input.focus();
  });

  // Expose API for the contact form to open chat with a pre-filled message
  (window as any).__crystalChat = {
    openWithMessage(msg: string) {
      open();
      // Simulate the user sending this message
      input.value = msg;
      form.dispatchEvent(new Event('submit'));
    }
  };
</script>

<style is:global>
  /* Container — no layout; children are individually fixed-positioned */
  .cw {
    font-family: var(--sans);
    pointer-events: none;
  }
  .cw > * {
    pointer-events: auto;
  }

  /* Collapsed button — accent color, centered bottom */
  .cw-bar {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 99px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(234, 90, 41, 0.3);
    transition: all 150ms ease;
  }
  .cw-bar:hover {
    background: var(--accent-hover);
    box-shadow: 0 6px 24px rgba(234, 90, 41, 0.4);
  }
  .cw-bar svg { opacity: 0.85; }
  .cw-bar { position: fixed; } /* ensure badge positions relative to button */
  .cw-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 18px;
    height: 18px;
    background: #e53e3e;
    border: 2.5px solid #fff;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(229, 62, 62, 0.4);
    animation: cw-badge-pulse 2s ease-in-out infinite;
  }
  @keyframes cw-badge-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  .cw-badge[hidden] { display: none !important; }

  /* Backdrop — blurs the entire page */
  .cw-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(250, 250, 247, 0.4);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 9998;
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .cw-backdrop[hidden] {
    display: none !important;
  }
  .cw-backdrop-visible {
    opacity: 1;
  }

  /* Chat panel */
  .cw-panel {
    position: fixed;
    bottom: 1.5rem;
    right: 50%;
    transform: translateX(50%) translateY(12px);
    width: 460px;
    max-width: calc(100vw - 2rem);
    height: 560px;
    max-height: calc(100vh - 4rem);
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 18px;
    box-shadow: 0 12px 50px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.03);
    flex-direction: column;
    overflow: hidden;
    z-index: 9999;
    opacity: 0;
    transition: opacity 250ms ease, transform 250ms ease;
  }
  .cw-panel[hidden] {
    display: none !important;
  }
  .cw-panel:not([hidden]) {
    display: flex;
  }
  .cw-panel-visible {
    opacity: 1;
    transform: translateX(50%) translateY(0);
  }

  /* Header */
  .cw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .cw-header-info {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .cw-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .cw-name {
    display: block;
    color: var(--ink);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .cw-status {
    display: block;
    color: var(--ink-muted);
    font-size: 0.75rem;
  }
  .cw-close {
    background: none;
    border: none;
    color: var(--ink-muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.2rem 0.35rem;
    line-height: 1;
    border-radius: 8px;
    transition: color 120ms, background 120ms;
  }
  .cw-close:hover {
    color: var(--ink);
    background: rgba(0, 0, 0, 0.04);
  }

  /* Messages */
  .cw-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .cw-msg p,
  .cw-msg .cw-bubble {
    margin: 0;
    padding: 0.7rem 0.95rem;
    border-radius: 16px;
    font-size: 0.9rem;
    line-height: 1.5;
    max-width: 82%;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .cw-msg-agent {
    display: flex;
    justify-content: flex-start;
  }
  .cw-msg-agent p,
  .cw-msg-agent .cw-bubble {
    background: rgba(0, 0, 0, 0.04);
    color: var(--ink);
    border-bottom-left-radius: 4px;
  }
  .cw-msg-user {
    display: flex;
    justify-content: flex-end;
  }
  .cw-msg-user p {
    background: var(--ink);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  /* Rendered markdown inside agent bubbles — tight spacing, no escaping bubble */
  .cw-msg-agent .cw-bubble > *:first-child { margin-top: 0; }
  .cw-msg-agent .cw-bubble > *:last-child { margin-bottom: 0; }
  .cw-msg-agent .cw-bubble p {
    margin: 0.4em 0;
    padding: 0;
    background: none;
    max-width: none;
    border-radius: 0;
    font-size: inherit;
    line-height: inherit;
  }
  .cw-msg-agent .cw-bubble h1,
  .cw-msg-agent .cw-bubble h2,
  .cw-msg-agent .cw-bubble h3,
  .cw-msg-agent .cw-bubble h4,
  .cw-msg-agent .cw-bubble h5,
  .cw-msg-agent .cw-bubble h6 {
    margin: 0.5em 0 0.25em;
    font-size: 1em;
    font-weight: 600;
    line-height: 1.3;
  }
  .cw-msg-agent .cw-bubble ul,
  .cw-msg-agent .cw-bubble ol {
    margin: 0.35em 0;
    padding-left: 1.25rem;
  }
  .cw-msg-agent .cw-bubble li { margin: 0.1em 0; }
  .cw-msg-agent .cw-bubble li > p { margin: 0; }
  .cw-msg-agent .cw-bubble a {
    color: var(--accent);
    text-decoration: underline;
  }
  .cw-msg-agent .cw-bubble a:hover { color: var(--accent-hover); }
  .cw-msg-agent .cw-bubble code {
    background: rgba(0, 0, 0, 0.06);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.85em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .cw-msg-agent .cw-bubble pre {
    margin: 0.5em 0;
    padding: 0.6rem 0.75rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 8px;
    overflow-x: auto;
    max-width: 100%;
  }
  .cw-msg-agent .cw-bubble pre code {
    background: none;
    padding: 0;
    font-size: 0.82em;
    white-space: pre;
  }
  .cw-msg-agent .cw-bubble blockquote {
    margin: 0.4em 0;
    padding-left: 0.75rem;
    border-left: 3px solid rgba(0, 0, 0, 0.12);
    color: var(--ink-muted);
  }
  .cw-msg-agent .cw-bubble hr {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    margin: 0.5em 0;
  }
  .cw-msg-agent .cw-bubble img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }
  .cw-msg-agent .cw-bubble table {
    border-collapse: collapse;
    font-size: 0.85em;
    margin: 0.4em 0;
  }
  .cw-msg-agent .cw-bubble th,
  .cw-msg-agent .cw-bubble td {
    border: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0.25em 0.5em;
  }

  /* Typing indicator */
  .cw-typing .cw-bubble {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 0.85rem 1rem;
  }
  .cw-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink-muted);
    opacity: 0.35;
    animation: cw-bounce 1.2s ease-in-out infinite;
  }
  .cw-dot:nth-child(2) { animation-delay: 0.15s; }
  .cw-dot:nth-child(3) { animation-delay: 0.3s; }
  @keyframes cw-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* Input */
  .cw-input {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }
  .cw-input input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--ink);
    font-size: 0.92rem;
    font-family: inherit;
    outline: none;
    padding: 0.4rem 0.25rem;
  }
  .cw-input input::placeholder {
    color: var(--ink-faint);
  }
  .cw-send {
    background: none;
    border: none;
    color: var(--ink-muted);
    cursor: pointer;
    padding: 0.35rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: color 120ms;
  }
  .cw-send:hover {
    color: var(--accent);
  }

  /* Scrollbar */
  .cw-messages::-webkit-scrollbar { width: 4px; }
  .cw-messages::-webkit-scrollbar-track { background: transparent; }
  .cw-messages::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.08); border-radius: 2px; }

  @media (max-width: 520px) {
    .cw-panel {
      width: calc(100vw - 1rem);
      height: calc(100vh - 2rem);
      bottom: 0.5rem;
      border-radius: 14px;
    }
  }
</style>
